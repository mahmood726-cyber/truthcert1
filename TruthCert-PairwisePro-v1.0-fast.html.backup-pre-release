// Living Meta-Analysis
const LivingMA = {
  history: [],
  addAnalysis: function(results, k) {
    const entry = {
      date: new Date().toISOString(),
      theta: results.pooled.theta,
      se: results.pooled.se,
      k: k,
      I2: results.het?.I2 || 0
    };
    this.history.push(entry);

    // Detect meaningful change
    const meaningful = this.history.length > 1 &&
      Math.abs(entry.theta - this.history[this.history.length - 2].theta) > 0.1;

    return { meaningful, entry };
  },
  reset: function() {
    this.history = [];
  }
};


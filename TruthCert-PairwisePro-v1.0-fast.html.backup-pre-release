// Metaoverfit Assessment - Fix to properly compute and update AppState.results
function updateMetaoverfitResults() {
  const r = AppState.results;
  if (!r || !r.yi) return;

  try {
    const k = r.yi.length;
    const p = 2; // theta and tau2 parameters
    const tau2 = r.tau2 || 0;
    const vi = r.vi;
    const ratio = k / p;

    // Calculate ESS (Effective Sample Size)
    const weights = vi.map(v => 1 / (v + tau2));
    const sumW = weights.reduce((a, b) => a + b, 0);
    const sumW2 = weights.reduce((a, w) => a + w * w, 0);
    const ESS = (sumW * sumW) / sumW2;

    let risk_level, interpretation, recommendation;
    if (ratio < 3) {
      risk_level = 'SEVERE';
      interpretation = `Only ${k} studies for ${p} parameters (ratio ${ratio.toFixed(1)}). τ² estimation highly unstable; standard errors likely too narrow.`;
      recommendation = 'Consider fixed-effect model, use HKSJ adjustment, or report as exploratory only.';
    } else if (ratio < 5) {
      risk_level = 'HIGH';
      interpretation = `${k} studies for ${p} parameters (ratio ${ratio.toFixed(1)}). Coverage probability may be below nominal; τ² may be biased.`;
      recommendation = 'Use HKSJ adjustment; report sensitivity to τ² estimator choice; interpret with caution.';
    } else if (ratio < 10) {
      risk_level = 'MODERATE';
      interpretation = `${k} studies for ${p} parameters (ratio ${ratio.toFixed(1)}). Adequate but not ideal; some instability possible with different τ² estimators.`;
      recommendation = 'Standard methods appropriate; consider reporting Q-profile CI for τ².';
    } else {
      risk_level = 'LOW';
      interpretation = `${k} studies for ${p} parameters (ratio ${ratio.toFixed(1)}). Sufficient for stable estimation.`;
      recommendation = 'Standard interpretation applies.';
    }

    // Update AppState.results.metaoverfit with proper data
    r.metaoverfit = {
      k: k,
      p: p,
      ratio: ratio,
      risk_level: risk_level,
      interpretation: interpretation,
      recommendation: recommendation,
      ESS: ESS,
      ESS_per_param: ESS / p
    };

    console.log('[Metaoverfit] Updated:', r.metaoverfit);

    // Re-render bias panel if visible
    if (typeof renderBiasPanel === 'function') {
      const biasPanel = document.getElementById('panel-bias');
      if (biasPanel && biasPanel.innerHTML.length > 100) {
        setTimeout(() => renderBiasPanel(r), 100);
      }
    }
  } catch (e) {
    console.error('updateMetaoverfitResults error:', e);
  }
}


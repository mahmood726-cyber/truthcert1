// Clinical Translation Compute
function computeClinical() {
  console.log('[Clinical] Starting computation...');
  const r = AppState.results;
  if (!r || !r.pooled) {
    showToast('Run analysis first', 'error');
    return;
  }

  const btn = event?.target;
  if (btn) { btn.disabled = true; btn.textContent = 'Computing...'; }

  try {
    const effect = r.pooled.theta;
    const se = r.pooled.se;
    const measure = r.measure || 'OR';
    const cer = parseFloat(document.getElementById('clinicalCER')?.value || 0.2);

    // Calculate NNT/NNH
    let nnt = null, nntInterpret = '';
    if (measure === 'OR' || measure === 'RR') {
      const rr = measure === 'OR' ? Math.exp(effect) / (1 - cer + cer * Math.exp(effect)) / (1 / (1 - cer)) : Math.exp(effect);
      const arr = cer * (1 - rr);
      if (Math.abs(arr) > 0.001) {
        nnt = Math.abs(1 / arr);
        nntInterpret = arr > 0 ? 'NNT (benefit)' : 'NNH (harm)';
      }
    } else if (measure === 'RD') {
      if (Math.abs(effect) > 0.001) {
        nnt = Math.abs(1 / effect);
        nntInterpret = effect < 0 ? 'NNT (benefit)' : 'NNH (harm)';
      }
    }

    // LaEV calculation
    const laev = Math.abs(effect) / se;
    const laevInterpret = laev > 2.8 ? 'Strong' : laev > 2 ? 'Moderate' : laev > 1 ? 'Weak' : 'Very weak';

    // Decision threshold
    const mcid = 0.15;
    const probBenefit = 1 - pnorm(mcid, effect, se);

    const container = document.getElementById('clinical-results');
    if (container) {
      container.innerHTML = `
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: var(--space-3);">
          <div class="stat-card">
            <div class="stat-card__label">Effect Size</div>
            <div class="stat-card__value">${effect.toFixed(4)}</div>
            <div class="stat-card__change">${measure}</div>
          </div>
          ${nnt ? `
          <div class="stat-card">
            <div class="stat-card__label">${nntInterpret}</div>
            <div class="stat-card__value">${nnt.toFixed(1)}</div>
            <div class="stat-card__change">patients per event</div>
          </div>
          ` : ''}
          <div class="stat-card">
            <div class="stat-card__label">LaEV Score</div>
            <div class="stat-card__value">${laev.toFixed(2)}</div>
            <div class="stat-card__change">${laevInterpret} evidence</div>
          </div>
          <div class="stat-card">
            <div class="stat-card__label">P(clinically meaningful)</div>
            <div class="stat-card__value">${(probBenefit * 100).toFixed(1)}%</div>
            <div class="stat-card__change">exceeds MCID</div>
          </div>
        </div>
      `;
    }
    showToast('Clinical translation complete', 'success');
  } catch (e) {
    showToast('Clinical failed: ' + e.message, 'error');
    console.error(e);
  } finally {
    if (btn) { btn.disabled = false; btn.textContent = '▶ Compute Clinical'; }
  }
}

// Helper: pnorm (standard normal CDF)
function pnorm(x, mean = 0, sd = 1) {
  const z = (x - mean) / sd;
  const t = 1 / (1 + 0.2316419 * Math.abs(z));
  const d = 0.3989423 * Math.exp(-z * z / 2);
  const p = d * t * (0.3193815 + t * (-0.3565638 + t * (1.781478 + t * (-1.821256 + t * 1.330274))));
  return z > 0 ? 1 - p : p;
}

// ML Outlier Detection
function mlOutlierDetection(yi, vi, names) {
  const k = yi.length;
  const sei = vi.map(v => Math.sqrt(v));

  // Standardize data
  const yMean = yi.reduce((a, b) => a + b, 0) / k;
  const ySD = Math.sqrt(yi.reduce((a, b) => a + Math.pow(b - yMean, 2), 0) / (k - 1));

  const scores = [];

  for (let i = 0; i < k; i++) {
    // Method 1: Standardized residuals
    const pooled = calculatePooledEstimate(yi, vi, estimateTau2_DL(yi, vi).tau2);
    const stdRes = Math.abs((yi[i] - pooled.theta) / Math.sqrt(vi[i] + pooled.tau2));

    // Method 2: LOO influence
    const yiLoo = yi.filter((_, j) => j !== i);
    const viLoo = vi.filter((_, j) => j !== i);
    const looResult = calculatePooledEstimate(yiLoo, viLoo, estimateTau2_DL(yiLoo, viLoo).tau2);
    const looInfluence = Math.abs(pooled.theta - looResult.theta) / pooled.se;

    // Method 3: Mahalanobis-like distance
    const mahal = Math.pow((yi[i] - yMean) / ySD, 2);

    // Method 4: Simple LOF approximation
    const distances = yi.map((y, j) => i !== j ? Math.abs(yi[i] - y) : Infinity);
    const kNearest = [...distances].sort((a, b) => a - b).slice(0, Math.min(3, k - 1));
    const lof = kNearest.reduce((a, b) => a + b, 0) / kNearest.length;

    // Method 5: Isolation score (simplified)
    const isolation = Math.abs(yi[i] - yMean) / (ySD || 1);

    // Ensemble score
    const ensemble = (stdRes / 3 + looInfluence / 2 + Math.sqrt(mahal) / 2 + lof / ySD + isolation / 2) / 5;

    scores.push({
      name: names[i],
      stdRes,
      looInfluence,
      mahal,
      lof,
      isolation,
      ensemble,
      isOutlier: stdRes > 2.5 || looInfluence > 1.5 || ensemble > 1.5
    });
  }

  const outliers = scores.filter(s => s.isOutlier);
  return {
    scores,
    outliers,
    nOutliers: outliers.length,
    method: '5-method ensemble'
  };
}


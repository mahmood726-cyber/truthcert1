              <td style="text-align: right; padding: var(--space-1);">${zSlope.toFixed(2)}</td>
              <td style="text-align: right; padding: var(--space-1); color: ${pSlope < 0.05 ? 'var(--color-success-500)' : 'inherit'};">${pSlope.toFixed(4)}</td>
            </tr>
          </tbody>
        </table>
        <div style="margin-top: var(--space-2); padding: var(--space-2); background: var(--surface-hover); border-radius: var(--radius-sm);">
          <p style="font-size: var(--text-sm);"><strong>R²:</strong> ${(r2 * 100).toFixed(1)}% of heterogeneity explained</p>
          <p style="font-size: var(--text-xs); color: var(--text-secondary); margin-top: var(--space-1);">
            ${pSlope < 0.05 ? `${covName} significantly moderates the effect (p < 0.05)` : `${covName} does not significantly moderate the effect`}
          </p>

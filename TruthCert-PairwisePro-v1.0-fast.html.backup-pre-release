// Analyze IPD
function analyzeIPD(ipd) {
  const studies = [...new Set(ipd.map(p => p.studyId))];
  const nStudies = studies.length;

  // One-stage analysis (simple pooling)
  const treated = ipd.filter(p => p.treatment === 1);
  const control = ipd.filter(p => p.treatment === 0);

  const meanT = treated.reduce((s, p) => s + p.outcome, 0) / treated.length;
  const meanC = control.reduce((s, p) => s + p.outcome, 0) / control.length;

  const varT = treated.reduce((s, p) => s + (p.outcome - meanT) ** 2, 0) / (treated.length - 1);
  const varC = control.reduce((s, p) => s + (p.outcome - meanC) ** 2, 0) / (control.length - 1);

  const effect = meanT - meanC;
  const se = Math.sqrt(varT / treated.length + varC / control.length);

  return {
    nStudies,
    nPatients: ipd.length,
    oneStage: {
      effect,
      se,
      ci_lower: effect - 1.96 * se,
      ci_upper: effect + 1.96 * se
    }
  };
}

// Generate Search Strategy
function generateSearchStrategy(studies, topic) {
  const terms = topic.split(/[\s,]+/).filter(t => t.length > 2);

  const pubmed = terms.length > 0
    ? `(${terms.map(t => `"${t}"[MeSH] OR "${t}"[tiab]`).join(' OR ')}) AND ("meta-analysis"[pt] OR "systematic review"[pt])`
    : '(meta-analysis[pt] OR systematic review[pt])';

  const cochrane = terms.length > 0
    ? terms.map(t => `"${t}":ti,ab,kw`).join(' AND ')
    : '*';

  const embase = terms.length > 0
    ? terms.map(t => `'${t}':ti,ab`).join(' AND ') + " AND 'meta analysis'/exp"
    : "'meta analysis'/exp";

  return {
    topic: topic || 'General',
    pubmed,
    cochrane,
    embase,
    studyCount: studies.length
  };
}


// Clinical Translation function
function clinicalTranslation(effect, se, cer = 0.2) {
  const smd = effect;  // Assuming effect is already SMD-like
  const oddsRatio = Math.exp(effect);
  const riskRatio = cer > 0 ? oddsRatio / (1 - cer + cer * oddsRatio) / (1 / (1 - cer)) : 1;
  const absoluteRiskReduction = cer * (1 - riskRatio);
  const nnt = Math.abs(absoluteRiskReduction) > 0.001 ? Math.round(Math.abs(1 / absoluteRiskReduction)) : Infinity;

  // Probability of superiority (Common Language Effect Size)
  const probSuperiority = pnorm(effect / Math.sqrt(2));

  // U3 - percent of control group below treatment mean
  const u3 = pnorm(effect);

  // Overlap coefficient
  const overlap = 2 * pnorm(-Math.abs(effect) / 2);

  // Magnitude interpretation
  let magnitude;
  if (Math.abs(smd) < 0.2) magnitude = 'Negligible';
  else if (Math.abs(smd) < 0.5) magnitude = 'Small';
  else if (Math.abs(smd) < 0.8) magnitude = 'Medium';
  else magnitude = 'Large';

  return {
    smd, oddsRatio, riskRatio, absoluteRiskReduction, nnt, probSuperiority, u3, overlap,
    interpretation: {
      magnitude,
      clinical: `Effect is ${magnitude.toLowerCase()}. NNT = ${nnt === Infinity ? '∞' : nnt}`,
      superiority: `${(probSuperiority * 100).toFixed(0)}% chance a treated patient does better than control`
    }
  };
}

// Fragility Index for MA (wrapper)
function fragilityIndexMA(yi, vi, pooledTheta) {
  const k = yi.length;
  const se = Math.sqrt(vi.reduce((a, b) => a + b, 0) / k);
  const z = pooledTheta / se;
  const pval = 2 * (1 - pnorm(Math.abs(z)));

  if (pval >= 0.05) {
    return {
      fragilityIndex: 0,
      fragilityQuotient: 0,
      interpretation: 'Result not significant; fragility index not applicable',
      robustness: 'N/A'
    };
  }

  // Simulate fragility by seeing how many sign flips needed
  let fi = 0;
  for (let flip = 1; flip <= k; flip++) {
    // Recalculate effect if we flip the most extreme study
    const sortedIdx = yi.map((y, i) => ({y, i})).sort((a, b) => Math.abs(b.y) - Math.abs(a.y));
    let modYi = [...yi];
    for (let j = 0; j < flip; j++) {
      modYi[sortedIdx[j].i] = -modYi[sortedIdx[j].i] * 0.5; // Attenuate flipped effects
    }
    const w = vi.map(v => 1/v);
    const sumW = w.reduce((a, b) => a + b, 0);
    const newTheta = modYi.reduce((sum, y, i) => sum + w[i] * y, 0) / sumW;
    const newSE = 1 / Math.sqrt(sumW);
    const newZ = newTheta / newSE;
    const newP = 2 * (1 - pnorm(Math.abs(newZ)));

    if (newP >= 0.05) {
      fi = flip;
      break;
    }
  }
  if (fi === 0) fi = k; // Never flipped

  const fq = fi / k;
  return {
    fragilityIndex: fi,
    fragilityQuotient: fq,
    interpretation: fi <= 2 ? 'Very fragile - small changes flip conclusion' :
                   fi <= 5 ? 'Moderately fragile' : 'Reasonably robust',
    robustness: fi >= 5 ? 'High' : fi >= 3 ? 'Moderate' : 'Low'
  };
}

// Sensitivity Engine
const SensitivityEngine = {
  state: {},
  init: function(results) {
    this.state = {
      originalTheta: results.pooled.theta,
      originalTau2: results.tau2,
      yi: results.yi,
      vi: results.vi,
      tau2Adj: 1.0,
      biasAdj: 0,
      priorMean: 0,
      priorSD: 10
    };
    console.log('[SensitivityEngine] Initialized');
  },
  update: function(param, value) {
    this.state[param] = value;
    return this.recalculate();
  },
  recalculate: function() {
    const { yi, vi, tau2Adj, biasAdj, priorMean, priorSD } = this.state;
    const adjYi = yi.map(y => y - biasAdj);
    const adjTau2 = (this.state.originalTau2 || 0.01) * tau2Adj;
    const w = vi.map(v => 1 / (v + adjTau2));
    const sumW = w.reduce((a, b) => a + b, 0);
    const theta = adjYi.reduce((sum, y, i) => sum + w[i] * y, 0) / sumW;
    const se = 1 / Math.sqrt(sumW);
    return { theta, se, ci: [theta - 1.96 * se, theta + 1.96 * se] };
  }
};


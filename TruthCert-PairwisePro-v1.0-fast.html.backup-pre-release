    <script>
    // Effect Size Calculator UI Functions
    function openEffectSizeCalculator() {
      document.getElementById('effectSizeCalculatorModal').style.display = 'flex';
    }
    function closeEffectSizeCalculator() {
      document.getElementById('effectSizeCalculatorModal').style.display = 'none';
    }
    function switchCalcTab(tabId) {
      document.querySelectorAll('.calc-tab-content').forEach(t => t.style.display = 'none');
      document.querySelectorAll('.tabs-nav .tab-btn').forEach(b => b.classList.remove('active'));
      document.getElementById('calc-' + tabId).style.display = 'block';
      event.target.classList.add('active');
      document.getElementById('calcResults').style.display = 'none';
    }
    function toggleComputeInputs() {
      const type = document.getElementById('computeInputType').value;
      document.getElementById('computeMeansInputs').style.display = type === 'means' ? 'grid' : 'none';
      document.getElementById('computeStatInputs').style.display = type !== 'means' ? 'grid' : 'none';
      const labels = { t: 't-value', F: 'F-value', chi2: 'Chi-square', p: 'p-value' };
      document.getElementById('statValueLabel').textContent = labels[type] || 't-value';
    }
    function runEffectSizeConversion() {
      const value = parseFloat(document.getElementById('calcInputValue').value);
      const from = document.getElementById('calcFromType').value;
      const to = document.getElementById('calcToType').value;
      const br = parseFloat(document.getElementById('calcBaselineRisk').value);
      const n = parseInt(document.getElementById('calcN').value);

      if (isNaN(value)) { alert('Please enter a valid value'); return; }

      try {
        const result = EffectSizeCalculator.convert(value, from, to, {
          baselineRisk: br, n1: n, n2: n
        });
        const resultsDiv = document.getElementById('calcResults');
        document.getElementById('calcResultsContent').innerHTML =
          '<p><strong>' + from + ' = ' + value.toFixed(4) + '</strong></p>' +
          '<p style="font-size:1.2em;color:var(--color-success-500);">' +
          '<strong>' + to + ' = ' + result.value.toFixed(4) + '</strong></p>';
        resultsDiv.style.display = 'block';
      } catch(e) {
        alert('Conversion error: ' + e.message);
      }
    }
    function computeEffectSize() {
      const type = document.getElementById('computeInputType').value;
      let result;

      try {
        if (type === 'means') {
          const m1 = parseFloat(document.getElementById('compM1').value);
          const sd1 = parseFloat(document.getElementById('compSD1').value);
          const n1 = parseInt(document.getElementById('compN1').value);
          const m2 = parseFloat(document.getElementById('compM2').value);
          const sd2 = parseFloat(document.getElementById('compSD2').value);
          const n2 = parseInt(document.getElementById('compN2').value);
          result = EffectSizeCalculator.fromMeansSD(m1, sd1, n1, m2, sd2, n2);
          document.getElementById('calcResultsContent').innerHTML =
            '<p><strong>Cohen\'s d:</strong> ' + result.d.toFixed(4) + ' (SE: ' + result.se_d.toFixed(4) + ')</p>' +
            '<p><strong>Hedges\' g:</strong> ' + result.g.toFixed(4) + ' (SE: ' + result.se_g.toFixed(4) + ')</p>' +
            '<p><strong>Pooled SD:</strong> ' + result.pooledSD.toFixed(4) + '</p>';
        } else {
          const statValue = parseFloat(document.getElementById('compStatValue').value);
          const n1 = parseInt(document.getElementById('compStatN1').value);
          const n2 = parseInt(document.getElementById('compStatN2').value);

          if (type === 't') result = EffectSizeCalculator.fromTStatistic(statValue, n1, n2);
          else if (type === 'F') result = EffectSizeCalculator.fromFStatistic(statValue, n1, n2);
          else if (type === 'chi2') result = EffectSizeCalculator.fromChiSquare(statValue, n1 + n2);
          else if (type === 'p') result = EffectSizeCalculator.fromPValue(statValue, n1, n2);

          document.getElementById('calcResultsContent').innerHTML =
            '<p><strong>Cohen\'s d:</strong> ' + result.d.toFixed(4) + '</p>' +
            (result.g ? '<p><strong>Hedges\' g:</strong> ' + result.g.toFixed(4) + '</p>' : '') +
            (result.r ? '<p><strong>Correlation r:</strong> ' + result.r.toFixed(4) + '</p>' : '');
        }
        document.getElementById('calcResults').style.display = 'block';
      } catch(e) {
        alert('Computation error: ' + e.message);
      }
    }
    function computeFrom2x2() {
      const a = parseInt(document.getElementById('table_a').value);
      const n1 = parseInt(document.getElementById('table_n1').value);
      const c = parseInt(document.getElementById('table_c').value);
      const n2 = parseInt(document.getElementById('table_n2').value);
      const b = n1 - a;
      const d = n2 - c;

      try {
        const result = EffectSizeCalculator.from2x2Table(a, b, c, d);
        document.getElementById('calcResultsContent').innerHTML =
          '<h5 style="margin:0 0 var(--space-2) 0;">Binary Effect Sizes</h5>' +
          '<p><strong>Odds Ratio:</strong> ' + result.OR.toFixed(3) + ' (95% CI: ' +
            Math.exp(result.logOR - 1.96*result.se_logOR).toFixed(3) + ' - ' +
            Math.exp(result.logOR + 1.96*result.se_logOR).toFixed(3) + ')</p>' +
          '<p><strong>Risk Ratio:</strong> ' + result.RR.toFixed(3) + ' (95% CI: ' +
            Math.exp(result.logRR - 1.96*result.se_logRR).toFixed(3) + ' - ' +
            Math.exp(result.logRR + 1.96*result.se_logRR).toFixed(3) + ')</p>' +
          '<p><strong>Risk Difference:</strong> ' + (result.RD*100).toFixed(1) + '% (95% CI: ' +
            ((result.RD - 1.96*result.se_RD)*100).toFixed(1) + '% - ' +
            ((result.RD + 1.96*result.se_RD)*100).toFixed(1) + '%)</p>' +
          (result.NNT ? '<p><strong>NNT:</strong> ' + result.NNT.toFixed(1) + '</p>' : '') +
          '<hr style="margin:var(--space-2) 0;opacity:0.3;">' +
          '<p><strong>P(treatment):</strong> ' + (result.p_treatment*100).toFixed(1) + '%</p>' +
          '<p><strong>P(control):</strong> ' + (result.p_control*100).toFixed(1) + '%</p>';
        document.getElementById('calcResults').style.display = 'block';
      } catch(e) {
        alert('Calculation error: ' + e.message);
      }
    }
    </script>


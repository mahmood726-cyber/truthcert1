// Fixed Meta-Regression that uses the selected covariate
window.runMetaRegression = function() {
  const r = AppState.results;
  if (!r || !r.studies) {
    showToast('Run analysis first', 'error');
    return;
  }

  const covariate = document.getElementById('metaregCovariateSelect')?.value || 'year';
  const studies = r.studies;
  const yi = studies.map(s => s.yi);
  const vi = studies.map(s => s.vi);

  let covValues;
  let covName;

  if (covariate === 'year') {
    covValues = studies.map((s, i) => s.year || (2000 + i));
    covName = 'Year';
  } else if (covariate === 'n_total') {
    covValues = studies.map(s => (s.n_t || 100) + (s.n_c || 100));
    covName = 'Sample Size';
  } else if (covariate === 'sei') {
    covValues = studies.map(s => s.sei || Math.sqrt(s.vi));
    covName = 'Standard Error';
  } else {
    covValues = studies.map((s, i) => i + 1);
    covName = 'Index';
  }

  // Center the covariate
  const covMean = covValues.reduce((a, b) => a + b, 0) / covValues.length;
  const covCentered = covValues.map(v => v - covMean);

  try {
    // Simple weighted regression
    const tau2 = r.heterogeneity?.tau2 || 0;
    const wi = vi.map(v => 1 / (v + tau2));
    const sumW = wi.reduce((a, b) => a + b, 0);

    // Weighted means
    const yBar = wi.reduce((a, w, i) => a + w * yi[i], 0) / sumW;
    const xBar = wi.reduce((a, w, i) => a + w * covCentered[i], 0) / sumW;

    // Slope
    let sxy = 0, sxx = 0;
    for (let i = 0; i < yi.length; i++) {
      sxy += wi[i] * (covCentered[i] - xBar) * (yi[i] - yBar);
      sxx += wi[i] * Math.pow(covCentered[i] - xBar, 2);
    }
    const slope = sxx > 0 ? sxy / sxx : 0;
    const intercept = yBar - slope * xBar;

    // Standard errors
    const slopeVar = sxx > 0 ? 1 / sxx : 0;
    const slopeSE = Math.sqrt(slopeVar);
    const interceptSE = Math.sqrt(1 / sumW + xBar * xBar * slopeVar);

    // Z and p values
    const zSlope = slopeSE > 0 ? slope / slopeSE : 0;
    const pSlope = 2 * (1 - pnorm(Math.abs(zSlope)));

    const zIntercept = interceptSE > 0 ? intercept / interceptSE : 0;
    const pIntercept = 2 * (1 - pnorm(Math.abs(zIntercept)));

    // R-squared
    const yPred = covCentered.map(x => intercept + slope * x);
    const ssRes = yi.reduce((a, y, i) => a + wi[i] * Math.pow(y - yPred[i], 2), 0);
    const ssTot = yi.reduce((a, y, i) => a + wi[i] * Math.pow(y - yBar, 2), 0);
    const r2 = ssTot > 0 ? Math.max(0, 1 - ssRes / ssTot) : 0;

    // Display results
    const container = document.getElementById('metaregResults');
    if (container) {
      container.innerHTML = `
        <h4 style="margin-bottom: var(--space-2);">Meta-Regression: ${covName}</h4>
        <table style="width: 100%; font-size: var(--text-sm); border-collapse: collapse;">
          <thead>
            <tr style="border-bottom: 2px solid var(--border-default);">
              <th style="text-align: left; padding: var(--space-1);">Term</th>
              <th style="text-align: right; padding: var(--space-1);">Estimate</th>
              <th style="text-align: right; padding: var(--space-1);">SE</th>
              <th style="text-align: right; padding: var(--space-1);">z</th>
              <th style="text-align: right; padding: var(--space-1);">p</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--border-subtle);">
              <td style="padding: var(--space-1);">Intercept</td>
              <td style="text-align: right; padding: var(--space-1);">${intercept.toFixed(4)}</td>
              <td style="text-align: right; padding: var(--space-1);">${interceptSE.toFixed(4)}</td>
              <td style="text-align: right; padding: var(--space-1);">${zIntercept.toFixed(2)}</td>
              <td style="text-align: right; padding: var(--space-1); color: ${pIntercept < 0.05 ? 'var(--color-success-500)' : 'inherit'};">${pIntercept.toFixed(4)}</td>
            </tr>

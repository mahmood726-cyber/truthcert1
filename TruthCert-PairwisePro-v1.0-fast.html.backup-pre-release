};

// Override the runLeaveOneOutCorrected to fix the error
window.runLeaveOneOutCorrected = function() {
  const r = AppState.results;
  if (!r || !r.studies) {
    showToast('Run analysis first', 'error');
    return;
  }

  const studies = r.studies;
  const yi = studies.map(s => s.yi);
  const vi = studies.map(s => s.vi);
  const names = studies.map(s => s.name);
  const k = yi.length;

  try {
    const tau2 = r.heterogeneity?.tau2 || estimateTau2_DL(yi, vi).tau2;
    const wi = vi.map(v => 1 / (v + tau2));
    const sumW = wi.reduce((a, b) => a + b, 0);
    const fullTheta = wi.reduce((a, w, i) => a + w * yi[i], 0) / sumW;
    const fullSE = Math.sqrt(1 / sumW);

    const looResults = [];
    for (let i = 0; i < k; i++) {
      const yiLoo = yi.filter((_, j) => j !== i);
      const viLoo = vi.filter((_, j) => j !== i);
      const tau2Loo = estimateTau2_DL(yiLoo, viLoo).tau2;
      const wiLoo = viLoo.map(v => 1 / (v + tau2Loo));
      const sumWLoo = wiLoo.reduce((a, b) => a + b, 0);
      const thetaLoo = wiLoo.reduce((a, w, j) => a + w * yiLoo[j], 0) / sumWLoo;
      const seLoo = Math.sqrt(1 / sumWLoo);

      looResults.push({
        omitted: names[i],
        theta: thetaLoo,
        se: seLoo,
        ci_lower: thetaLoo - 1.96 * seLoo,
        ci_upper: thetaLoo + 1.96 * seLoo,
        change: thetaLoo - fullTheta
      });
    }

    // Find most influential
    const maxChange = Math.max(...looResults.map(r => Math.abs(r.change)));
    const mostInfluential = looResults.find(r => Math.abs(r.change) === maxChange);

    // Display results
    const container = document.getElementById('looResults');
    if (container) {
      let html = `
        <p style="margin-bottom: var(--space-2);"><strong>Full model:</strong> ${fullTheta.toFixed(4)} (SE: ${fullSE.toFixed(4)})</p>
        <p style="margin-bottom: var(--space-2);"><strong>Most influential:</strong> ${mostInfluential?.omitted || 'None'} (change: ${maxChange.toFixed(4)})</p>
        <table style="width: 100%; font-size: var(--text-xs); border-collapse: collapse;">
          <thead>
            <tr style="border-bottom: 2px solid var(--border-default);">
              <th style="text-align: left; padding: 4px;">Omitted</th>
              <th style="text-align: right; padding: 4px;">Effect</th>
              <th style="text-align: right; padding: 4px;">95% CI</th>
              <th style="text-align: right; padding: 4px;">Change</th>
            </tr>
          </thead>
          <tbody>
      `;

      for (const r of looResults) {
        const highlight = Math.abs(r.change) === maxChange ? 'background: var(--color-warning-100);' : '';
        html += `
          <tr style="${highlight} border-bottom: 1px solid var(--border-subtle);">
            <td style="padding: 4px;">${r.omitted}</td>
            <td style="text-align: right; padding: 4px;">${r.theta.toFixed(4)}</td>
            <td style="text-align: right; padding: 4px;">[${r.ci_lower.toFixed(3)}, ${r.ci_upper.toFixed(3)}]</td>
            <td style="text-align: right; padding: 4px;">${r.change >= 0 ? '+' : ''}${r.change.toFixed(4)}</td>
          </tr>
        `;
      }

      html += '</tbody></table>';
      container.innerHTML = html;
    }

    // Render plot
    if (typeof Plotly !== 'undefined' && document.getElementById('looPlot')) {
      const trace = {
        x: looResults.map(r => r.theta),
        y: looResults.map(r => r.omitted),
        error_x: {
          type: 'data',
          symmetric: false,
          array: looResults.map(r => r.ci_upper - r.theta),
          arrayminus: looResults.map(r => r.theta - r.ci_lower)
        },
        type: 'scatter',
        mode: 'markers',
        marker: { size: 8, color: '#2E86AB' }
      };

      const fullLine = {
        x: [fullTheta, fullTheta],
        y: [looResults[0].omitted, looResults[k-1].omitted],
        type: 'scatter',
        mode: 'lines',
        line: { color: '#E94F37', width: 2, dash: 'dash' },
        name: 'Full estimate'
      };

      Plotly.newPlot('looPlot', [trace, fullLine], {
        xaxis: { title: 'Effect Size', zeroline: true },
        yaxis: { automargin: true },
        height: 300,
        margin: { l: 120, r: 20, t: 20, b: 40 },
        showlegend: false,
        paper_bgcolor: 'rgba(0,0,0,0)',
        plot_bgcolor: 'rgba(0,0,0,0)'
      }, { responsive: true });
    }

    showToast('Leave-one-out analysis complete', 'success');
  } catch (e) {
    showToast('LOO analysis failed: ' + e.message, 'error');
    console.error(e);
  }
};


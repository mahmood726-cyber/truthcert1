// Cumulative Meta-Analysis
function runCumulativeAnalysis() {
  if (!AppState.results || !AppState.results.studies) {
    showToast('Run analysis first', 'warning');
    return;
  }

  const studies = AppState.results.studies;
  const yi = studies.map(s => s.yi);
  const vi = studies.map(s => s.vi);
  const names = studies.map(s => s.name);
  const years = studies.map(s => s.year || 2000);

  try {
    // By year
    const byYear = cumulativeByYear(yi, vi, years, names);
    renderCumulativePlot(byYear, 'cumYearPlot', 'By Publication Year');

    // By precision
    const byPrecision = cumulativeByPrecision(yi, vi, names);
    renderCumulativePlot(byPrecision, 'cumPrecisionPlot', 'By Precision');

    showToast('Cumulative analysis complete', 'success');
  } catch (e) {
    showToast('Cumulative analysis failed: ' + e.message, 'error');
    console.error(e);
  }
}

function cumulativeByYear(yi, vi, years, names) {
  const indices = years.map((y, i) => ({ year: y, idx: i, name: names[i] }))
    .sort((a, b) => a.year - b.year);

  const results = [];
  for (let i = 0; i < indices.length; i++) {
    const subset = indices.slice(0, i + 1).map(d => d.idx);
    const yiSub = subset.map(j => yi[j]);
    const viSub = subset.map(j => vi[j]);
    const tau2 = estimateTau2_DL(yiSub, viSub).tau2;
    const pooled = calculatePooledEstimate(yiSub, viSub, tau2);

    results.push({
      k: i + 1,
      label: `+${indices[i].name} (${indices[i].year})`,
      theta: pooled.theta,
      se: pooled.se,
      ci_lower: pooled.theta - 1.96 * pooled.se,
      ci_upper: pooled.theta + 1.96 * pooled.se
    });
  }
  return results;
}

function cumulativeByPrecision(yi, vi, names) {
  const sei = vi.map(v => Math.sqrt(v));
  const indices = sei.map((s, i) => ({ se: s, idx: i, name: names[i] }))
    .sort((a, b) => a.se - b.se);

  const results = [];
  for (let i = 0; i < indices.length; i++) {
    const subset = indices.slice(0, i + 1).map(d => d.idx);
    const yiSub = subset.map(j => yi[j]);
    const viSub = subset.map(j => vi[j]);
    const tau2 = estimateTau2_DL(yiSub, viSub).tau2;
    const pooled = calculatePooledEstimate(yiSub, viSub, tau2);

    results.push({
      k: i + 1,
      label: `+${indices[i].name}`,
      theta: pooled.theta,
      se: pooled.se,
      ci_lower: pooled.theta - 1.96 * pooled.se,
      ci_upper: pooled.theta + 1.96 * pooled.se
    });
  }
  return results;
}

function renderCumulativePlot(data, containerId, title) {
  const container = document.getElementById(containerId);
  if (!container || typeof Plotly === 'undefined') {
    // Fallback to text
    if (container) {
      let html = `<table style="width:100%; font-size: var(--text-xs);"><thead><tr><th>Step</th><th>Effect</th><th>95% CI</th></tr></thead><tbody>`;
      data.forEach(d => {
        html += `<tr><td>${d.label}</td><td>${d.theta.toFixed(3)}</td><td>[${d.ci_lower.toFixed(3)}, ${d.ci_upper.toFixed(3)}]</td></tr>`;
      });
      html += '</tbody></table>';
      container.innerHTML = html;
    }
    return;
  }

  const trace = {
    x: data.map(d => d.theta),
    y: data.map(d => d.label),
    error_x: {
      type: 'data',
      symmetric: false,
      array: data.map(d => d.ci_upper - d.theta),
      arrayminus: data.map(d => d.theta - d.ci_lower)
    },
    type: 'scatter',
    mode: 'markers',
    marker: { size: 8, color: '#2E86AB' }
  };

  const layout = {
    title: { text: title, font: { size: 12 } },
    xaxis: { title: 'Effect Size', zeroline: true, zerolinecolor: '#999' },
    yaxis: { automargin: true },
    height: 300,
    margin: { l: 150, r: 20, t: 40, b: 40 },
    paper_bgcolor: 'rgba(0,0,0,0)',
    plot_bgcolor: 'rgba(0,0,0,0)'
  };

  Plotly.newPlot(container, [trace], layout, { responsive: true });
}

// Power Analysis
function runPowerAnalysis() {
  if (!AppState.results || !AppState.results.studies) {
    showToast('Run analysis first', 'warning');
    return;
  }

  const r = AppState.results;
  const k = r.studies.length;
  const effect = Math.abs(r.pooled.theta);
  const se = r.pooled.se;
  const tau2 = r.heterogeneity?.tau2 || 0;

  // Power calculation
  const alpha = 0.05;
  const zAlpha = 1.96;
  const power = 1 - pnorm(zAlpha - effect / se) + pnorm(-zAlpha - effect / se);

  // Required sample size for 80% power
  const zBeta = 0.84;
  const requiredN = Math.ceil(Math.pow((zAlpha + zBeta) * se / effect, 2));

  const container = document.getElementById('powerResults');
  if (container) {
    container.innerHTML = `
      <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-3);">
        <div class="stat-card">
          <div class="stat-card__label">Current Power</div>
          <div class="stat-card__value" style="color: ${power > 0.8 ? 'var(--color-success-500)' : 'var(--color-warning-500)'}">
            ${(power * 100).toFixed(1)}%
          </div>
          <div class="stat-card__change">at α = 0.05</div>
        </div>
        <div class="stat-card">
          <div class="stat-card__label">Studies for 80% Power</div>
          <div class="stat-card__value">${requiredN}</div>
          <div class="stat-card__change">currently have ${k}</div>
        </div>
      </div>
      <p style="margin-top: var(--space-2); font-size: var(--text-xs); color: var(--text-secondary);">
        Power analysis assumes fixed effect size. With τ² = ${tau2.toFixed(4)}, actual power may vary.
      </p>
    `;
  }

  // Render power curve
  renderPowerCurve('powerPlot', effect, se, k);

  showToast(`Power: ${(power * 100).toFixed(1)}%`, power > 0.8 ? 'success' : 'warning');
}

function renderPowerCurve(containerId, effect, se, currentK) {
  const container = document.getElementById(containerId);
  if (!container || typeof Plotly === 'undefined') return;

  const kValues = Array.from({ length: 30 }, (_, i) => i + 1);
  const powers = kValues.map(k => {
    const adjSE = se * Math.sqrt(currentK / k);
    return 1 - pnorm(1.96 - effect / adjSE) + pnorm(-1.96 - effect / adjSE);
  });

  const trace = {
    x: kValues,
    y: powers.map(p => p * 100),
    type: 'scatter',
    mode: 'lines+markers',
    line: { color: '#2E86AB', width: 2 },
    marker: { size: 4 }
  };

  const currentPoint = {
    x: [currentK],
    y: [powers[currentK - 1] * 100],
    type: 'scatter',
    mode: 'markers',
    marker: { size: 12, color: '#E94F37', symbol: 'star' },
    name: 'Current'
  };

  const layout = {
    xaxis: { title: 'Number of Studies' },
    yaxis: { title: 'Power (%)', range: [0, 100] },
    shapes: [{ type: 'line', x0: 0, x1: 30, y0: 80, y1: 80, line: { dash: 'dash', color: '#999' } }],
    height: 250,
    margin: { l: 50, r: 20, t: 20, b: 40 },
    showlegend: false,
    paper_bgcolor: 'rgba(0,0,0,0)',
    plot_bgcolor: 'rgba(0,0,0,0)'
  };

  Plotly.newPlot(container, [trace, currentPoint], layout, { responsive: true });
}


// runSimplifiedMA - for comprehensive analysis
function runSimplifiedMA() {
  if (!AppState.results || !AppState.results.studies) return;

  const studies = AppState.results.studies;
  const yi = studies.map(s => s.yi);
  const vi = studies.map(s => s.vi);

  // Simple model averaging with 2 estimators
  const dlTau2 = estimateTau2_DL(yi, vi).tau2;
  const dlPooled = calculatePooledEstimate(yi, vi, dlTau2);

  const fePooled = calculatePooledEstimate(yi, vi, 0);

  // Weight by inverse variance of estimates
  const dlWeight = 0.7;
  const feWeight = 0.3;

  const avgTheta = dlWeight * dlPooled.theta + feWeight * fePooled.theta;
  const pEffect = 1 - pnorm(-Math.abs(avgTheta) / dlPooled.se);

  const results = {
    averaged: { theta: avgTheta, se: dlPooled.se },
    models: [
      { name: 'DL Random', theta: dlPooled.theta, weight: dlWeight },
      { name: 'Fixed Effect', theta: fePooled.theta, weight: feWeight }
    ],
    pEffect,
    interpretation: pEffect > 0.95 ? 'Strong evidence of effect' :
                   pEffect > 0.8 ? 'Moderate evidence' : 'Weak evidence'
  };

  document.getElementById('modelavgResults').innerHTML = `
    <div style="background: var(--bg-secondary); padding: var(--space-3); border-radius: var(--radius-md);">
      <p><strong>Model-Averaged Effect:</strong> ${results.averaged.theta.toFixed(3)}</p>
      <p>P(effect ≠ 0): <strong>${(results.pEffect * 100).toFixed(1)}%</strong></p>
      <ul style="margin: var(--space-2) 0 0 var(--space-3);">
        ${results.models.map(m => `<li>${m.name}: θ=${m.theta.toFixed(3)} (weight=${(m.weight*100).toFixed(0)}%)</li>`).join('')}
      </ul>
      <p style="color: ${results.pEffect > 0.9 ? 'var(--color-success-500)' : 'var(--color-warning-500)'}; font-weight: bold; margin-top: var(--space-2);">
        ${results.interpretation}
      </p>
    </div>
  `;
  showToast('ModelAvg complete', 'success');
}

